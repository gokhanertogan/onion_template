{
  "Service": {
    "Name": "ai-analyzer-worker"
  },
  "Otlp": {
    "Endpoint": "http://localhost:4317"
  },
  "Elasticsearch": {
    "BaseUrl": "http://localhost:9200"
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com",
    "Model": "gpt-4.1"
  },
  "GitHub": {
    "BaseUrl": "https://api.github.com",
    "Owner": "gokhanertogan",
    "Repository": "observability-platform",
    "DefaultBranch": "main",
    "EnableIssuePrAutomation": false
  },
  "Analyzer": {
    "IntervalSeconds": 20,
    "MaxLogsFetched": 400,
    "MaxProblematicTraces": 3,
    "MaxLogsPerTrace": 30,
    "OutputDirectory": "./analysis-output"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}